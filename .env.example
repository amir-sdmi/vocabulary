# Required: Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_token_here

# Required: NextAuth / Google OAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret
GOOGLE_CLIENT_ID=google_client_id_here
GOOGLE_CLIENT_SECRET=google_client_secret_here

# Required for Telegram webhook protection (recommended)
TELEGRAM_BOT_TOKEN=telegram_bot_token_here
TELEGRAM_WEBHOOK_SECRET=telegram_webhook_secret_here

# Fill later when you connect external services
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
